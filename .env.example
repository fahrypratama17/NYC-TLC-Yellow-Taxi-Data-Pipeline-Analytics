# ── NYC TLC ingestion ──────────────────────────────────
# Months to ingest. Format: YYYY-MM, comma-separated.
TLC_MONTHS=2025-01,2025-02,2025-03,2025-04,2025-05,2025-06
TLC_TAXI_TYPE=yellow

# Base path for the TLC parquet host (CloudFront).
TLC_BASE_URL=https://d37ci6vzurychx.cloudfront.net/trip-data

# Taxi zones shapefile (NYC OpenData).
TLC_ZONES_URL=https://d37ci6vzurychx.cloudfront.net/misc/taxi_zones.zip

# ── Open-Meteo Historical Weather API ──────────────────
# Free, no API key required. Coordinates of NYC (Manhattan, midtown).
WEATHER_LATITUDE=40.7580
WEATHER_LONGITUDE=-73.9855
WEATHER_TIMEZONE=America/New_York

# ── Storage ────────────────────────────────────────────
DATA_DIR=./data
DUCKDB_PATH=./data/warehouse.duckdb

